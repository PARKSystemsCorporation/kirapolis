{
  "name": "kiradex",
  "version": "0.1.0",
  "private": true,
  "description": "KiraDex control plane for local website teams. Agents build only in C:\\parks\\web\\newpark.",
  "workspaces": [
    "apps/*",
    "services/*",
    "extensions/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @kiradex/agent --workspace @kiradex/desktop",
    "typecheck": "npm run typecheck --workspace @kiradex/agent --workspace @kiradex/desktop",
    "start": "npm run build && electron apps/desktop/dist/main.js",
    "start:agent": "npm run build --workspace @kiradex/agent && node services/agent/dist/server.js",
    "clean": "node scripts/clean.mjs"
  }
}
