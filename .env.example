# Kirapolis local runtime

# Core paths
KIRA_CONTROL_ROOT=.
KIRA_PROJECT_ROOT=.

# Agent service
KIRA_HOST=0.0.0.0
KIRA_PORT=4317
KIRA_PROVIDER=ollama
KIRA_PUBLIC_BASE_URL=

# Local model endpoints
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENCLAW_BASE_URL=http://127.0.0.1:11434

# Optional webhook protection
KIRA_RAILWAY_WEBHOOK_SECRET=

# Optional model overrides
KIRA_MODEL=
KIRA_MODEL_EXECUTIVE=
KIRA_MODEL_CODER=
KIRA_MODEL_FAST=
KIRA_MODEL_EMBEDDING=
