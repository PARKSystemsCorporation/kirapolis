# Kirapolis runtime configuration
#
# This file is safe to commit because it only contains placeholders.
# Real secrets belong in local `.env` files or Railway service variables only.

# Core paths (defaults to repo root)
KIRA_CONTROL_ROOT=.
KIRA_PROJECT_ROOT=.

# Agent service
# Local default host/port. On Railway, the app will automatically use `PORT`
# and bind to `0.0.0.0`, so these usually do not need to be set there.
KIRA_HOST=127.0.0.1
KIRA_PORT=4317
KIRA_PROVIDER=ollama
KIRA_PUBLIC_BASE_URL=

# Access password (leave blank to disable auth)
KIRA_ACCESS_PASSWORD=

# Runtime labeling
# Set these in Railway variables if you want the dashboard to identify Railway explicitly.
# Keep `local` for a desktop or workstation-driven model-lab workflow.
# For Railway, use:
# KIRA_RUNTIME_MODE=railway
# KIRA_MODEL_LAB_EXECUTION_TARGET=railway
KIRA_RUNTIME_MODE=local
KIRA_MODEL_LAB_EXECUTION_TARGET=local
KIRA_MODEL_LAB_MACHINE_LABEL=

# Model endpoints
# For local development, point at your local Ollama instance.
# For Railway deployment, point at your remote Ollama instance
# (e.g. via Tailscale IP, Cloudflare tunnel, or another Railway service).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENCLAW_BASE_URL=http://127.0.0.1:11434

# Optional webhook protection
KIRA_RAILWAY_WEBHOOK_SECRET=

# Optional model overrides (leave blank to use defaults)
KIRA_MODEL=
KIRA_MODEL_EXECUTIVE=
KIRA_MODEL_CODER=
KIRA_MODEL_FAST=
KIRA_MODEL_EMBEDDING=
